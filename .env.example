# Application
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000

# Swagger
ENABLE_SWAGGER=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bookeepa

# JWT (for authentication)
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=3600

# Environment-specific settings
# For production, ensure NODE_ENV=production to disable Swagger UI by default
